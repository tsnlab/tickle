#include <stdio.h>
#include <unistd.h>

#include "srv/{{ srv_name }}.h"

static void {{ srv_name | lower }}_callback(struct tt_Client* client, int8_t return_code, struct {{ srv_unique_name }}Response* response) {
    if (return_code == 0 && response == NULL) {
        printf("  Server not found\n");
    } else if (return_code != 0) {
        printf("  Error, return_code: %d\n", return_code);
    } else {
        printf("  return_code: %d\n", return_code);
    }
}

static void set_request(struct {{ srv_unique_name }}Request* request) {
    *request = (struct {{ srv_unique_name }}Request){};
    // assign members of request
}

static void call(struct tt_Node* node, uint64_t time, void* param) {
    struct tt_Client* client = param;
    struct {{ srv_unique_name }}Request request;

    set_request(&request);
    printf("Second call\n");
    int32_t ret = tt_Client_call(client, (struct tt_Request*)&request);
    if (ret < 0) {
        printf("Cannot call: %d\n", ret);
    }
}

int main(int argc, char* argv) {
    _tt_CONFIG.broadcast = "192.168.10.255";

    struct tt_Node node;
    int32_t ret = tt_Node_create(&node);
    if (ret != 0) {
        printf("Cannot create node: %d\n", ret);
        return ret;
    }

    printf("Node created(#%d)\n", node.id);

    struct tt_Client client;

    ret = tt_Node_create_client(&node, &client, &{{ srv_unique_name }}Service, "{{ srv_name | lower }}_server",
                                (tt_CLIENT_CALLBACK){{ srv_name | lower }}_callback);
    if (ret != 0) {
        printf("Cannot create server: %d\n", ret);
        return ret;
    }

    struct {{ srv_unique_name }}Request request;
    set_request(&request);
    ret = tt_Client_call(&client, (struct tt_Request*)&request);
    if (ret < 0) {
        printf("Cannot call: %d\n", ret);
    }

    tt_Node_schedule(&node, tt_get_ns() + tt_SECOND, call, &client);
    tt_Node_schedule(&node, tt_get_ns() + 2 * tt_SECOND, call, &client);
    tt_Node_schedule(&node, tt_get_ns() + 3 * tt_SECOND, call, &client);

    tt_Node_poll(&node);

    tt_Node_destroy(&node);

    return 0;
}
