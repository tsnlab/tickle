#!/bin/bash

# Pre-push hook script for clang-format and clang-tidy
# This script runs clang-format and clang-tidy on C/C++ files before pushing

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${YELLOW}Running pre-push checks...${NC}"

# Get the list of files that will be pushed
files_to_check=()
while read local_ref local_sha remote_ref remote_sha; do
    if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
        # Handle delete
        continue
    fi
    
    if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
        # New branch, examine all commits
        range="$local_sha"
    else
        # Update to existing branch, examine new commits
        range="$remote_sha..$local_sha"
    fi
    
    # Get changed files
    changed_files=$(git diff --name-only --diff-filter=ACMR "$range" | grep -E '\.(c|cpp|h|hpp)$' || true)
    if [ -n "$changed_files" ]; then
        files_to_check+=($changed_files)
    fi
done

# Remove duplicates
files_to_check=($(printf "%s\n" "${files_to_check[@]}" | sort -u))

if [ ${#files_to_check[@]} -eq 0 ]; then
    echo -e "${GREEN}No C/C++ files to check.${NC}"
    exit 0
fi

echo -e "${YELLOW}Checking ${#files_to_check[@]} C/C++ files...${NC}"

# Check if clang-format is available
if ! command -v clang-format &> /dev/null; then
    echo -e "${RED}Error: clang-format is not installed or not in PATH${NC}"
    exit 1
fi

# Check if clang-tidy is available
if ! command -v clang-tidy &> /dev/null; then
    echo -e "${RED}Error: clang-tidy is not installed or not in PATH${NC}"
    exit 1
fi

# Check if compile_commands.json exists
if [ ! -f "compile_commands.json" ]; then
    echo -e "${YELLOW}Warning: compile_commands.json not found. clang-tidy may not work properly.${NC}"
    echo -e "${YELLOW}Consider running 'cmake -DCMAKE_EXPORT_COMPILE_COMMANDS=ON' to generate it.${NC}"
fi

# Function to check if file exists and is readable
check_file() {
    local file="$1"
    if [ ! -f "$file" ]; then
        echo -e "${YELLOW}Warning: File $file does not exist, skipping...${NC}"
        return 1
    fi
    if [ ! -r "$file" ]; then
        echo -e "${YELLOW}Warning: File $file is not readable, skipping...${NC}"
        return 1
    fi
    return 0
}

# Run clang-format check
echo -e "${YELLOW}Running clang-format check...${NC}"
format_errors=0
for file in "${files_to_check[@]}"; do
    if check_file "$file"; then
        echo -n "Checking format: $file ... "
        if clang-format --dry-run --Werror "$file" > /dev/null 2>&1; then
            echo -e "${GREEN}OK${NC}"
        else
            echo -e "${RED}FAILED${NC}"
            echo -e "${RED}File $file is not properly formatted. Run 'clang-format -i $file' to fix.${NC}"
            format_errors=$((format_errors + 1))
        fi
    fi
done

# Run clang-tidy check
echo -e "${YELLOW}Running clang-tidy check...${NC}"
tidy_errors=0
for file in "${files_to_check[@]}"; do
    if check_file "$file"; then
        echo -n "Checking tidy: $file ... "
        if clang-tidy "$file" --quiet 2>/dev/null; then
            echo -e "${GREEN}OK${NC}"
        else
            echo -e "${RED}FAILED${NC}"
            echo -e "${RED}File $file has clang-tidy issues. Check the output above for details.${NC}"
            tidy_errors=$((tidy_errors + 1))
        fi
    fi
done

# Summary
echo -e "\n${YELLOW}=== Summary ===${NC}"
if [ $format_errors -eq 0 ] && [ $tidy_errors -eq 0 ]; then
    echo -e "${GREEN}All checks passed! Ready to push.${NC}"
    exit 0
else
    echo -e "${RED}Pre-push checks failed:${NC}"
    if [ $format_errors -gt 0 ]; then
        echo -e "${RED}  - $format_errors file(s) have formatting issues${NC}"
    fi
    if [ $tidy_errors -gt 0 ]; then
        echo -e "${RED}  - $tidy_errors file(s) have clang-tidy issues${NC}"
    fi
    echo -e "\n${YELLOW}To fix formatting issues, run:${NC}"
    echo -e "${YELLOW}  clang-format -i <file>${NC}"
    echo -e "\n${YELLOW}To fix clang-tidy issues, check the output above and fix the reported problems.${NC}"
    echo -e "\n${YELLOW}To skip this check (not recommended), use:${NC}"
    echo -e "${YELLOW}  git push --no-verify${NC}"
    exit 1
fi
